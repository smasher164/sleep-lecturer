# Copy this file to .env and fill in your own values.
#
# OpenAI — used to generate lecture transcripts
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ElevenLabs — used for text-to-speech synthesis
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Local model via Ollama (optional)
# Set LOCAL_BASE_URL to enable the local provider selector in the UI.
# LOCAL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL=llama3.2

